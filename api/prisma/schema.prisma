// Apophis SMM Suite — data model
// Postgres + Prisma. Money & leave-days are Decimal, never Float.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  FINANCE
  HR
  VIEWER
}

enum InvoiceStatus {
  PENDING
  IN_PROGRESS
  PAID
  OVERDUE
}

enum TxnType {
  INCOME
  EXPENSE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

// PLANNED = filed in advance, still draws casual
enum LeaveMode {
  NORMAL
  PLANNED
}

// Mirrors the workbook codes: P L A WFH CL SL PL CO LOP H EM
enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  WFH
  CASUAL
  SICK
  PLANNED
  COMP_OFF
  LOP
  HOLIDAY
  EMERGENCY
}

enum LeavePolicyType {
  ACCRUAL_LOT
  MONTHLY_QUOTA
  PAID_THRESHOLD
  DISCRETIONARY
}

enum AdjustmentType {
  LATE_DEDUCTION
  LOP_SICK
  LOP_LEAVE
  LOP_WFH
  STAR_BONUS
}

model User {
  id            String   @id @default(cuid())
  empId         String?  @unique
  name          String
  designation   String?
  email         String   @unique
  passwordHash  String
  role          Role     @default(VIEWER)
  dailyRate     Decimal? @db.Decimal(12, 2)
  createdAt     DateTime @default(now())

  transactions  Transaction[]
  leaveRequests LeaveRequest[]      @relation("requester")
  approvals     LeaveRequest[]      @relation("approver")
  attendance    AttendanceRecord[]
  grants        LeaveGrant[]
  adjustments   PayrollAdjustment[]
  merits        MeritRecord[]
  stars         StarAward[]
}

model Client {
  id        String    @id @default(cuid())
  name      String
  company   String?
  email     String?
  phone     String?
  contact   String?
  notes     String?
  createdAt DateTime  @default(now())
  invoices  Invoice[]
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id])
  amount        Decimal       @db.Decimal(12, 2)
  currency      String        @default("INR")
  issueDate     DateTime      @default(now())
  dueDate       DateTime
  status        InvoiceStatus @default(PENDING)
  salesStatus   String?
  notes         String?
  payments      Payment[]
  reminders     Reminder[]
}

model Payment {
  id        String   @id @default(cuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id])
  amount    Decimal  @db.Decimal(12, 2)
  paidDate  DateTime @default(now())
  method    String?
  reference String?
}

model Reminder {
  id           String    @id @default(cuid())
  invoiceId    String
  invoice      Invoice   @relation(fields: [invoiceId], references: [id])
  kind         String    @default("OVERDUE")
  channel      String    @default("EMAIL")
  scheduledFor DateTime
  sentAt       DateTime?
  status       String    @default("SCHEDULED")
}

model Category {
  id           String        @id @default(cuid())
  name         String
  type         TxnType
  transactions Transaction[]
}

model Budget {
  id            String   @id @default(cuid())
  name          String
  periodStart   DateTime
  periodEnd     DateTime
  plannedAmount Decimal  @db.Decimal(12, 2)
}

model Transaction {
  id          String    @id @default(cuid())
  type        TxnType
  amount      Decimal   @db.Decimal(12, 2)
  date        DateTime  @default(now())
  description String?
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
}

model LeaveType {
  id                String          @id @default(cuid())
  name              String          @unique
  policyType        LeavePolicyType
  monthlyGrant      Decimal?        @db.Decimal(6, 2)
  maxBalance        Decimal?        @db.Decimal(6, 2)
  lotLifetimeMonths Int?
  paidThreshold     Decimal?        @db.Decimal(6, 2)
  paid              Boolean         @default(true)
  grants            LeaveGrant[]
  requests          LeaveRequest[]
}

model LeaveGrant {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  leaveTypeId String
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])
  amount      Decimal   @db.Decimal(6, 2)
  used        Decimal   @db.Decimal(6, 2) @default(0)
  grantedOn   DateTime
  expiresOn   DateTime?
  @@index([userId, leaveTypeId])
}

model LeaveRequest {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation("requester", fields: [userId], references: [id])
  leaveTypeId String
  leaveType   LeaveType   @relation(fields: [leaveTypeId], references: [id])
  mode        LeaveMode   @default(NORMAL)
  startDate   DateTime
  endDate     DateTime
  days        Decimal     @db.Decimal(6, 2)
  status      LeaveStatus @default(PENDING)
  shortNotice Boolean     @default(false)
  paidDays    Decimal?    @db.Decimal(6, 2)
  lopDays     Decimal?    @db.Decimal(6, 2)
  approverId  String?
  approver    User?       @relation("approver", fields: [approverId], references: [id])
  createdAt   DateTime    @default(now())
}

model AttendanceRecord {
  id               String           @id @default(cuid())
  userId           String
  user             User             @relation(fields: [userId], references: [id])
  date             DateTime
  checkIn          DateTime?
  checkOut         DateTime?
  status           AttendanceStatus @default(PRESENT)
  hours            Decimal?         @db.Decimal(5, 2)
  late             Boolean          @default(false)
  refusedAfterLate Boolean          @default(false)
  @@unique([userId, date])
}

model PayrollAdjustment {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id])
  date         DateTime
  type         AdjustmentType
  unitFraction Decimal?       @db.Decimal(5, 2)
  amount       Decimal?       @db.Decimal(12, 2)
  sourceType   String
  sourceId     String?
  note         String?
  @@unique([userId, date, type, sourceId])
}

model MeritRecord {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  month     String
  points    Int      @default(0)
  reasons   String
  @@unique([userId, month])
}

model StarAward {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])
  month  String
  amount Decimal @db.Decimal(12, 2) @default(5000)
  @@unique([month])
}
